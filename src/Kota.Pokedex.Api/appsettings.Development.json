{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    },
    "Console": {
      "FormatterName": "json",
      "FormatterOptions": {
        "TimestampFormat": "O",
        "UseUtcTimestamp": true,
        "IncludeScopes": true
      }
    }
  },
  "Cache": {
    "Provider": "Memory"
  }
}
