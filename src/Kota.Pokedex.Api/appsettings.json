{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
      "FormatterName": "json",
      "FormatterOptions": {
        "TimestampFormat": "O",
        "UseUtcTimestamp": true,
        "IncludeScopes": true
      }
    }
  },
  "AllowedHosts": "*",
  "Cache": {
    "Provider": "Memory",
    "DefaultTtlMinutes": 1440
  },
  "ConnectionStrings": {
    "redis": "localhost:6379",
    "PokedexDb": "Data Source=pokedex.db"
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowMinutes": 1
  },
  "PokeApi": {
    "BaseUrl": "https://pokeapi.co/api/v2/",
    "MaxConcurrentRequests": 5,
    "PageFetchLimit": 100
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "Jwt": {
    "Secret": "dev-only-change-in-production-min-32-chars!!",
    "Issuer": "Kota.Pokedex",
    "Audience": "Kota.Pokedex.Client",
    "ExpiryMinutes": 60
  }
}
